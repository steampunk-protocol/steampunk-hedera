# ============================================================================
# Steampunk — Environment Configuration
# ============================================================================
# Copy to .env and fill in your values.
# Agent wallets go in .env.agents (see .env.agents.example)
# ============================================================================

# --- Hedera Network ---
HEDERA_NETWORK=testnet
HEDERA_TESTNET_RPC=https://testnet.hashio.io/api
HEDERA_CHAIN_ID=296

# --- Operator Account ---
# Get a free testnet account at https://portal.hedera.com
HEDERA_OPERATOR_ID=
HEDERA_OPERATOR_KEY=
DEPLOYER_KEY=

# --- Arena Server Private Key (for oracle signing + settlement) ---
ARENA_PRIVATE_KEY=

# --- Deployed Resources (populated after scripts/setup-hedera.ts) ---
# Current testnet values:
#   STEAM_TOKEN_ID=0.0.8187171
#   STEAM_TOKEN_EVM_ADDRESS=0x00000000000000000000000000000000007ced23
#   HCS_MATCH_RESULTS_TOPIC=0.0.8187173
#   HCS_MATCHMAKER_TOPIC=0.0.8205003
STEAM_TOKEN_ID=
STEAM_TOKEN_EVM_ADDRESS=
HCS_MATCH_RESULTS_TOPIC=
HCS_MATCHMAKER_TOPIC=

# --- Smart Contracts V2 (non-upgradeable, deployed to Hedera testnet) ---
# Current testnet values:
#   WAGER_CONTRACT_ADDRESS=0x00000000000000000000000000000000007f58e4
#   MATCH_PROOF_CONTRACT_ADDRESS=0x08Fd822b6c5Cb32CF9229EA3D394F1dc11E2CE79
#   PREDICTION_POOL_CONTRACT_ADDRESS=0xbf5071FcD7d9fECc5522298865070B4508BB23cC
WAGER_CONTRACT_ADDRESS=
MATCH_PROOF_CONTRACT_ADDRESS=
PREDICTION_POOL_CONTRACT_ADDRESS=

# --- Arena Server ---
ARENA_PORT=8000
ARENA_BASE_URL=http://localhost:8000
DATABASE_URL=sqlite:///./arena.db
ORACLE_PRIVATE_KEY=
BETTING_WINDOW_S=60

# --- Frontend ---
NEXT_PUBLIC_WALLET_CONNECT_ID=
NEXT_PUBLIC_HEDERA_TESTNET_RPC=https://testnet.hashio.io/api
NEXT_PUBLIC_MIRROR_NODE=https://testnet.mirrornode.hedera.com/api/v1
NEXT_PUBLIC_ARENA_API_URL=http://localhost:8000
NEXT_PUBLIC_ARENA_WS_URL=ws://localhost:8000
NEXT_PUBLIC_PREDICTION_POOL_ADDRESS=
NEXT_PUBLIC_MATCH_PROOF_ADDRESS=
NEXT_PUBLIC_WAGER_ADDRESS=
NEXT_PUBLIC_STEAM_TOKEN_ADDRESS=
NEXT_PUBLIC_HCS_MATCH_RESULTS_TOPIC=

# --- AI / LLM (optional — for LLM-powered agent strategy) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
