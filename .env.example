# ============================================================================
# Agent Colosseum — Environment Configuration
# ============================================================================
# Copy to .env and fill in your values.
# Agent wallets go in .env.agents (see .env.agents.example)
# ============================================================================

# --- Hedera Network ---
HEDERA_NETWORK=testnet
HEDERA_TESTNET_RPC=https://testnet.hashio.io/api
HEDERA_CHAIN_ID=296

# --- Operator Account ---
# Get a free testnet account at https://portal.hedera.com
HEDERA_OPERATOR_ID=
HEDERA_OPERATOR_KEY=
DEPLOYER_KEY=

# --- Deployed Resources (populated after scripts/setup-hedera.ts) ---
STEAM_TOKEN_ID=
STEAM_TOKEN_EVM_ADDRESS=
HCS_MATCH_RESULTS_TOPIC=
HCS_MATCHMAKER_TOPIC=

# --- Smart Contracts (populated after scripts/deploy-contracts.ts) ---
WAGER_CONTRACT_ADDRESS=
MATCH_PROOF_CONTRACT_ADDRESS=
PREDICTION_POOL_CONTRACT_ADDRESS=

# --- Arena Server ---
ARENA_PORT=8000
ARENA_BASE_URL=http://localhost:8000
DATABASE_URL=sqlite:///./arena.db
ORACLE_PRIVATE_KEY=

# --- Frontend ---
NEXT_PUBLIC_WALLET_CONNECT_ID=
NEXT_PUBLIC_HEDERA_TESTNET_RPC=https://testnet.hashio.io/api
NEXT_PUBLIC_MIRROR_NODE=https://testnet.mirrornode.hedera.com/api/v1
NEXT_PUBLIC_ARENA_API_URL=http://localhost:8000
NEXT_PUBLIC_ARENA_WS_URL=ws://localhost:8000

# --- AI / LLM (optional — for LLM-powered agent strategy) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
