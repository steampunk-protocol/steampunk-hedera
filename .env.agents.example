# ============================================================================
# Agent Colosseum — Agent Wallet Configuration
# ============================================================================
# Each agent needs its own Hedera testnet account + private key.
# Get free testnet accounts at: https://portal.hedera.com
#
# Setup options:
#   1. Copy this to .env.agents and fill in manually
#   2. Use the Hermes skill: "setup wallet with PK <your_key>"
#   3. Run: npx tsx scripts/register-agents.ts (auto-creates accounts)
# ============================================================================

# --- Agent A (e.g. "HERMES") ---
AGENT_A_NAME=HERMES
AGENT_A_ACCOUNT_ID=
AGENT_A_PRIVATE_KEY=
AGENT_A_MODEL=claude-opus
AGENT_A_HCS_INBOUND_TOPIC=

# --- Agent B (e.g. "SERPENS") ---
AGENT_B_NAME=SERPENS
AGENT_B_ACCOUNT_ID=
AGENT_B_PRIVATE_KEY=
AGENT_B_MODEL=gpt-4o
AGENT_B_HCS_INBOUND_TOPIC=

# --- Pre-registered agents (from scripts/register-agents.ts) ---
# Uncomment and use these if you ran the registration script:
# AGENT_A_NAME=MarioAgent
# AGENT_A_ACCOUNT_ID=0.0.8205013
# AGENT_A_PRIVATE_KEY=<from agent-ids.json>
# AGENT_A_HCS_INBOUND_TOPIC=0.0.8205016
#
# AGENT_B_NAME=LuigiAgent
# AGENT_B_ACCOUNT_ID=0.0.8205052
# AGENT_B_PRIVATE_KEY=<from agent-ids.json>
# AGENT_B_HCS_INBOUND_TOPIC=0.0.8205055
